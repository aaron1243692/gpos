@{
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty);
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty);
    var title = ViewData["Title"]?.ToString() ?? "Dashboard";
    var module = ModuleName(ViewData["Section"]?.ToString(), currentController);
    var username = Context.Session.GetString("Username")
        ?? Context.Session.GetString("Name")
        ?? User.Identity?.Name
        ?? "User";

    bool IsActive(string controller, string action) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

    bool IsCurrentRoute(string controller, string action) => IsActive(controller, action);

    var headerGroups = new[]
    {
        new
        {
            Name = "Setup",
            Pages = new[]
            {
                new { Label = "Customers", Controller = "Setup", Action = "Customers" },
                new { Label = "Suppliers", Controller = "Setup", Action = "Suppliers" },
                new { Label = "Categories", Controller = "Setup", Action = "Categories" },
                new { Label = "Item Units", Controller = "Setup", Action = "ItemUnits" },
                new { Label = "Fuel Units", Controller = "Setup", Action = "FuelUnits" },
                new { Label = "Fuel Types", Controller = "Setup", Action = "FuelTypes" },
                new { Label = "Products", Controller = "Setup", Action = "Products" },
                new { Label = "Pump Units", Controller = "Setup", Action = "PumpUnits" },
                new { Label = "Pumps", Controller = "Setup", Action = "Pumps" },
                new { Label = "Tanks", Controller = "Setup", Action = "FuelTanks" },
                new { Label = "Fuel Prices", Controller = "Setup", Action = "FuelPriceHistory" },
                new { Label = "Discounts", Controller = "Setup", Action = "Discounts" }
            }
        },
        new
        {
            Name = "Transactions",
            Pages = new[]
            {
                new { Label = "Open Shift", Controller = "Transaction", Action = "OpenShift" },
                new { Label = "Beginning Balance", Controller = "Transaction", Action = "DailyBeginningBalance" },
                new { Label = "POS", Controller = "Transaction", Action = "PosProductSales" },
                new { Label = "Fuel Transactions", Controller = "Transaction", Action = "PumpTransaction" },
                new { Label = "Product Sales", Controller = "Transaction", Action = "PosProductSales" },
                new { Label = "Points Redemption", Controller = "Transaction", Action = "PointsRedemption" },
                new { Label = "End Shift", Controller = "Transaction", Action = "DailyClosingBalance" },
                new { Label = "Receipt Preview", Controller = "Transaction", Action = "ReceiptPreview" },
                new { Label = "Payments", Controller = "Transaction", Action = "TransactionPayments" },
                new { Label = "Cash Drawer", Controller = "Transaction", Action = "CashDrawerMovement" },
                new { Label = "Cash Turnover", Controller = "Transaction", Action = "CashTurnover" },
                new { Label = "Void", Controller = "Transaction", Action = "VoidTransactions" }
            }
        },
        new
        {
            Name = "Reports",
            Pages = new[]
            {
                new { Label = "Daily Sales", Controller = "Reports", Action = "DailySalesReport" },
                new { Label = "Fuel Sales", Controller = "Reports", Action = "FuelSalesReport" },
                new { Label = "Product Sales", Controller = "Reports", Action = "ProductSalesReport" },
                new { Label = "Shift Sales", Controller = "Reports", Action = "ShiftSalesReport" },
                new { Label = "Inventory", Controller = "Reports", Action = "InventoryReport" },
                new { Label = "Points", Controller = "Reports", Action = "PointsReport" },
                new { Label = "Cashier", Controller = "Reports", Action = "CashierSalesReport" },
                new { Label = "Payments", Controller = "Reports", Action = "PaymentMethodReport" },
                new { Label = "Discounts", Controller = "Reports", Action = "DiscountReport" },
                new { Label = "Customers", Controller = "Reports", Action = "CustomerReport" },
                new { Label = "Fuel Tanks", Controller = "Reports", Action = "FuelTankReport" },
                new { Label = "Fuel Batches", Controller = "Reports", Action = "FuelBatchReport" },
                new { Label = "Item Batches", Controller = "Reports", Action = "ItemBatchReport" },
                new { Label = "Cash Difference", Controller = "Reports", Action = "CashDifferenceReport" },
                new { Label = "Void Transactions", Controller = "Reports", Action = "VoidTransactionReport" }
            }
        },
        new
        {
            Name = "Inventory",
            Pages = new[]
            {
                new { Label = "Warehouse", Controller = "Inventory", Action = "WarehouseInventory" },
                new { Label = "Display", Controller = "Inventory", Action = "DisplayInventory" },
                new { Label = "Receiving", Controller = "Inventory", Action = "StockReceiving" },
                new { Label = "Transfer", Controller = "Inventory", Action = "StockTransfer" },
                new { Label = "Adjustment", Controller = "Inventory", Action = "StockAdjustment" },
                new { Label = "Low Stock", Controller = "Inventory", Action = "LowStockItems" },
                new { Label = "Item Batches", Controller = "Inventory", Action = "ItemBatches" },
                new { Label = "Fuel Batches", Controller = "Inventory", Action = "FuelBatches" },
                new { Label = "Fuel Delivery", Controller = "Inventory", Action = "FuelDelivery" },
                new { Label = "Fuel Movement", Controller = "Inventory", Action = "FuelInventoryMovement" },
                new { Label = "Item Movement", Controller = "Inventory", Action = "ItemInventoryMovement" }
            }
        },
        new
        {
            Name = "Users",
            Pages = new[]
            {
                new { Label = "Users", Controller = "Setup", Action = "Users" },
                new { Label = "Profile", Controller = "Setup", Action = "Profile" },
                new { Label = "Settings", Controller = "Setup", Action = "Settings" },
                new { Label = "Activity Logs", Controller = "Logs", Action = "ActivityLogs" }
            }
        }
    };

    var activeHeaderGroup = headerGroups.FirstOrDefault(group => group.Pages.Any(page => IsCurrentRoute(page.Controller, page.Action)))
        ?? headerGroups.First();

    string ModuleName(string? section, string controller)
    {
        if (!string.IsNullOrWhiteSpace(section))
        {
            return section.Equals("Transaction", StringComparison.OrdinalIgnoreCase) ? "Transactions" : section;
        }

        return controller switch
        {
            "Setup" => "Setup",
            "Transaction" => "Transactions",
            "Inventory" => "Inventory",
            "Reports" => "Reports",
            "Logs" => "System",
            "Dashboard" => "Dashboard",
            _ => "GPOS"
        };
    }

    string UserInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length >= 2)
        {
            return string.Concat(parts[0][0], parts[1][0]).ToUpperInvariant();
        }

        return name.Length > 0 ? name[0].ToString().ToUpperInvariant() : "U";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - GPOS</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/gpos.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <div class="app-layout">
        <main class="app-main">
            <header class="eg-rb" data-gpos-ribbon aria-label="Primary navigation">
                <div class="eg-rb-top">
                    <a class="eg-rb-brand" asp-controller="Dashboard" asp-action="Index" aria-label="GPOS dashboard">
                        <span class="eg-rb-brand-mark" aria-hidden="true">G</span>
                        <span>GPOS / Gas Station POS</span>
                    </a>

                    <nav class="eg-rb-tabs" aria-label="Main page groups">
                        @foreach (var group in headerGroups)
                        {
                            var landingPage = group.Pages.First();
                            var isActiveGroup = string.Equals(activeHeaderGroup.Name, group.Name, StringComparison.OrdinalIgnoreCase);
                            <a class="eg-rb-tab @(isActiveGroup ? "is-active" : "")"
                               asp-controller="@landingPage.Controller"
                               asp-action="@landingPage.Action">
                                @group.Name
                            </a>
                        }
                    </nav>

                    <details class="eg-rb-user" id="gposUserDropdown">
                        <summary class="eg-rb-userbtn" aria-controls="gposUserMenu">
                            <span class="eg-rb-avatar" aria-hidden="true">@UserInitials(username)</span>
                            <span class="eg-rb-userlabel">@username</span>
                            <span class="eg-rb-usercaret" aria-hidden="true"></span>
                        </summary>
                        <div class="eg-rb-usermenu" id="gposUserMenu" role="menu">
                            <div class="eg-rb-usercaption">Signed in as</div>
                            <div class="eg-rb-username">@username</div>
                            <form asp-controller="SignIn" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button class="eg-rb-usermenu-link eg-rb-usermenu-link--danger" type="submit" role="menuitem">
                                    Logout
                                </button>
                            </form>
                        </div>
                    </details>
                </div>

                <div class="eg-rb-ribbon">
                    <section class="eg-rb-group">
                        <div class="eg-rb-group-title">@activeHeaderGroup.Name</div>
                        <nav class="eg-rb-items" aria-label="@activeHeaderGroup.Name pages">
                            @foreach (var headerPage in activeHeaderGroup.Pages)
                            {
                                var isActivePage = IsCurrentRoute(headerPage.Controller, headerPage.Action);
                                <a class="eg-rb-tile @(isActivePage ? "is-active" : "")"
                                   asp-controller="@headerPage.Controller"
                                   asp-action="@headerPage.Action">
                                    <span class="eg-rb-icon" aria-hidden="true">@headerPage.Label.Substring(0, Math.Min(3, headerPage.Label.Length)).ToUpperInvariant()</span>
                                    <span>@headerPage.Label</span>
                                </a>
                            }
                        </nav>
                    </section>
                </div>
            </header>
            <div class="app-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
