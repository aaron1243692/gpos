@{
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty);
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty);
    var title = ViewData["Title"]?.ToString() ?? "Dashboard";
    var module = ModuleName(ViewData["Section"]?.ToString(), currentController);
    var username = Context.Session.GetString("Username")
        ?? Context.Session.GetString("Name")
        ?? User.Identity?.Name
        ?? "User";

    bool IsActive(string controller, string action) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

    bool IsGroupActive(params string[] controllers) =>
        controllers.Any(controller => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase));

    string ModuleName(string? section, string controller)
    {
        if (!string.IsNullOrWhiteSpace(section))
        {
            return section.Equals("Transaction", StringComparison.OrdinalIgnoreCase) ? "Transactions" : section;
        }

        return controller switch
        {
            "Setup" => "Setup",
            "Transaction" => "Transactions",
            "Inventory" => "Inventory",
            "Reports" => "Reports",
            "Logs" => "System",
            "Dashboard" => "Dashboard",
            _ => "GPOS"
        };
    }

    string UserInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length >= 2)
        {
            return string.Concat(parts[0][0], parts[1][0]).ToUpperInvariant();
        }

        return name.Length > 0 ? name[0].ToString().ToUpperInvariant() : "U";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - GPOS</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/gpos.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <nav class="mobile-topbar navbar navbar-dark d-lg-none">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">GPOS</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#appSidebar" aria-controls="appSidebar" aria-label="Open navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </nav>

    <div class="app-layout">
        <aside class="app-sidebar offcanvas-lg offcanvas-start" tabindex="-1" id="appSidebar" aria-labelledby="appSidebarLabel">
            <div class="sidebar-header">
                <div class="brand-lockup">
                    <span class="brand-mark" aria-hidden="true">G</span>
                    <div>
                        <a class="sidebar-brand" asp-controller="Dashboard" asp-action="Index" id="appSidebarLabel">GPOS</a>
                        <div class="sidebar-subtitle">Gas Station POS</div>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white d-lg-none" data-bs-dismiss="offcanvas" data-bs-target="#appSidebar" aria-label="Close"></button>
            </div>

            <nav class="sidebar-nav accordion" id="sidebarMenu">
                <div class="nav-group">
                    <a class="nav-group-toggle text-decoration-none @(IsActive("Dashboard", "Index") ? "active" : "collapsed")" asp-controller="Dashboard" asp-action="Index">
                        <span>Dashboard</span>
                    </a>
                </div>

                <div class="nav-group">
                    <button class="nav-group-toggle @(IsGroupActive("Setup") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#setupMenu" aria-expanded="@IsGroupActive("Setup").ToString().ToLowerInvariant()">
                        <span>Setup</span><span class="chevron"></span>
                    </button>
                    <div id="setupMenu" class="collapse @(IsGroupActive("Setup") ? "show" : "")" data-bs-parent="#sidebarMenu">
                        <a class="sidebar-link @(IsActive("Setup", "Users") ? "active" : "")" asp-controller="Setup" asp-action="Users">Users</a>
                        <a class="sidebar-link @(IsActive("Setup", "Customers") ? "active" : "")" asp-controller="Setup" asp-action="Customers">Customers</a>
                        <a class="sidebar-link @(IsActive("Setup", "Suppliers") ? "active" : "")" asp-controller="Setup" asp-action="Suppliers">Suppliers</a>
                        <a class="sidebar-link @(IsActive("Setup", "Categories") ? "active" : "")" asp-controller="Setup" asp-action="Categories">Categories</a>
                        <a class="sidebar-link @(IsActive("Setup", "ItemUnits") ? "active" : "")" asp-controller="Setup" asp-action="ItemUnits">Item Units</a>
                        <a class="sidebar-link @(IsActive("Setup", "FuelUnits") ? "active" : "")" asp-controller="Setup" asp-action="FuelUnits">Fuel Units</a>
                        <a class="sidebar-link @(IsActive("Setup", "Products") ? "active" : "")" asp-controller="Setup" asp-action="Products">Products</a>
                        <a class="sidebar-link @(IsActive("Setup", "FuelTypes") ? "active" : "")" asp-controller="Setup" asp-action="FuelTypes">Fuel Types</a>
                        <a class="sidebar-link @(IsActive("Setup", "PumpUnits") ? "active" : "")" asp-controller="Setup" asp-action="PumpUnits">Pump Units</a>
                        <a class="sidebar-link @(IsActive("Setup", "Pumps") ? "active" : "")" asp-controller="Setup" asp-action="Pumps">Pumps</a>
                        <a class="sidebar-link @(IsActive("Setup", "FuelTanks") ? "active" : "")" asp-controller="Setup" asp-action="FuelTanks">Tanks</a>
                        <a class="sidebar-link @(IsActive("Setup", "FuelPriceHistory") ? "active" : "")" asp-controller="Setup" asp-action="FuelPriceHistory">Fuel Price Settings</a>
                        <a class="sidebar-link @(IsActive("Setup", "Discounts") ? "active" : "")" asp-controller="Setup" asp-action="Discounts">Discounts</a>
                    </div>
                </div>

                <div class="nav-group">
                    <button class="nav-group-toggle @(IsGroupActive("Transaction") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#transactionMenu" aria-expanded="@IsGroupActive("Transaction").ToString().ToLowerInvariant()">
                        <span>Transactions</span><span class="chevron"></span>
                    </button>
                    <div id="transactionMenu" class="collapse @(IsGroupActive("Transaction") ? "show" : "")" data-bs-parent="#sidebarMenu">
                        <a class="sidebar-link @(IsActive("Transaction", "OpenShift") ? "active" : "")" asp-controller="Transaction" asp-action="OpenShift">Open Shift</a>
                        <a class="sidebar-link @(IsActive("Transaction", "DailyBeginningBalance") ? "active" : "")" asp-controller="Transaction" asp-action="DailyBeginningBalance">Daily Beginning Balance</a>
                        <a class="sidebar-link @(IsActive("Transaction", "PumpTransaction") ? "active" : "")" asp-controller="Transaction" asp-action="PumpTransaction">Pump Transaction</a>
                        <a class="sidebar-link @(IsActive("Transaction", "PosProductSales") ? "active" : "")" asp-controller="Transaction" asp-action="PosProductSales">POS Product Sales</a>
                        <a class="sidebar-link @(IsActive("Transaction", "PointsRedemption") ? "active" : "")" asp-controller="Transaction" asp-action="PointsRedemption">Points Redemption</a>
                        <a class="sidebar-link @(IsActive("Transaction", "DailyClosingBalance") ? "active" : "")" asp-controller="Transaction" asp-action="DailyClosingBalance">Daily Closing Balance</a>
                        <a class="sidebar-link @(IsActive("Transaction", "ReceiptPreview") ? "active" : "")" asp-controller="Transaction" asp-action="ReceiptPreview">Receipt Preview</a>
                        <a class="sidebar-link @(IsActive("Transaction", "TransactionPayments") ? "active" : "")" asp-controller="Transaction" asp-action="TransactionPayments">Transaction Payments</a>
                        <a class="sidebar-link @(IsActive("Transaction", "CashDrawerMovement") ? "active" : "")" asp-controller="Transaction" asp-action="CashDrawerMovement">Cash Drawer Movement</a>
                        <a class="sidebar-link @(IsActive("Transaction", "CashTurnover") ? "active" : "")" asp-controller="Transaction" asp-action="CashTurnover">Cash Turnover</a>
                        <a class="sidebar-link @(IsActive("Transaction", "VoidTransactions") ? "active" : "")" asp-controller="Transaction" asp-action="VoidTransactions">Void Transactions</a>
                    </div>
                </div>

                <div class="nav-group">
                    <button class="nav-group-toggle @(IsGroupActive("Inventory") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#inventoryMenu" aria-expanded="@IsGroupActive("Inventory").ToString().ToLowerInvariant()">
                        <span>Inventory</span><span class="chevron"></span>
                    </button>
                    <div id="inventoryMenu" class="collapse @(IsGroupActive("Inventory") ? "show" : "")" data-bs-parent="#sidebarMenu">
                        <a class="sidebar-link @(IsActive("Inventory", "WarehouseInventory") ? "active" : "")" asp-controller="Inventory" asp-action="WarehouseInventory">Warehouse Inventory</a>
                        <a class="sidebar-link @(IsActive("Inventory", "DisplayInventory") ? "active" : "")" asp-controller="Inventory" asp-action="DisplayInventory">Display / Sales Inventory</a>
                        <a class="sidebar-link @(IsActive("Inventory", "StockTransfer") ? "active" : "")" asp-controller="Inventory" asp-action="StockTransfer">Stock Transfer</a>
                        <a class="sidebar-link @(IsActive("Inventory", "StockAdjustment") ? "active" : "")" asp-controller="Inventory" asp-action="StockAdjustment">Stock Adjustment</a>
                        <a class="sidebar-link @(IsActive("Inventory", "StockReceiving") ? "active" : "")" asp-controller="Inventory" asp-action="StockReceiving">Purchase / Receiving</a>
                        <a class="sidebar-link @(IsActive("Inventory", "LowStockItems") ? "active" : "")" asp-controller="Inventory" asp-action="LowStockItems">Low Stock</a>
                        <a class="sidebar-link @(IsActive("Inventory", "ItemBatches") ? "active" : "")" asp-controller="Inventory" asp-action="ItemBatches">Item Batches</a>
                        <a class="sidebar-link @(IsActive("Inventory", "FuelBatches") ? "active" : "")" asp-controller="Inventory" asp-action="FuelBatches">Fuel Batches</a>
                        <a class="sidebar-link @(IsActive("Inventory", "FuelDelivery") ? "active" : "")" asp-controller="Inventory" asp-action="FuelDelivery">Fuel Delivery</a>
                        <a class="sidebar-link @(IsActive("Inventory", "FuelInventoryMovement") ? "active" : "")" asp-controller="Inventory" asp-action="FuelInventoryMovement">Fuel Inventory Movement</a>
                        <a class="sidebar-link @(IsActive("Inventory", "ItemInventoryMovement") ? "active" : "")" asp-controller="Inventory" asp-action="ItemInventoryMovement">Item Inventory Movement</a>
                    </div>
                </div>

                <div class="nav-group">
                    <button class="nav-group-toggle @(IsGroupActive("Reports") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#reportsMenu" aria-expanded="@IsGroupActive("Reports").ToString().ToLowerInvariant()">
                        <span>Reports</span><span class="chevron"></span>
                    </button>
                    <div id="reportsMenu" class="collapse @(IsGroupActive("Reports") ? "show" : "")" data-bs-parent="#sidebarMenu">
                        <a class="sidebar-link @(IsActive("Reports", "DailySalesReport") ? "active" : "")" asp-controller="Reports" asp-action="DailySalesReport">Sales Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "FuelSalesReport") ? "active" : "")" asp-controller="Reports" asp-action="FuelSalesReport">Fuel Sales Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "ProductSalesReport") ? "active" : "")" asp-controller="Reports" asp-action="ProductSalesReport">Product Sales Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "ShiftSalesReport") ? "active" : "")" asp-controller="Reports" asp-action="ShiftSalesReport">Shift Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "InventoryReport") ? "active" : "")" asp-controller="Reports" asp-action="InventoryReport">Inventory Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "PointsReport") ? "active" : "")" asp-controller="Reports" asp-action="PointsReport">Customer Points Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "CashierSalesReport") ? "active" : "")" asp-controller="Reports" asp-action="CashierSalesReport">Cashier Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "DiscountReport") ? "active" : "")" asp-controller="Reports" asp-action="DiscountReport">Discount Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "PaymentMethodReport") ? "active" : "")" asp-controller="Reports" asp-action="PaymentMethodReport">Payment Method Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "CustomerReport") ? "active" : "")" asp-controller="Reports" asp-action="CustomerReport">Customer Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "FuelTankReport") ? "active" : "")" asp-controller="Reports" asp-action="FuelTankReport">Fuel Tank Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "FuelBatchReport") ? "active" : "")" asp-controller="Reports" asp-action="FuelBatchReport">Fuel Batch Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "ItemBatchReport") ? "active" : "")" asp-controller="Reports" asp-action="ItemBatchReport">Item Batch Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "CashDifferenceReport") ? "active" : "")" asp-controller="Reports" asp-action="CashDifferenceReport">Cash Difference Report</a>
                        <a class="sidebar-link @(IsActive("Reports", "VoidTransactionReport") ? "active" : "")" asp-controller="Reports" asp-action="VoidTransactionReport">Void Transaction Report</a>
                    </div>
                </div>

                <div class="nav-group">
                    <button class="nav-group-toggle @(IsGroupActive("Logs") || IsActive("Setup", "Settings") || IsActive("Setup", "Profile") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#systemMenu" aria-expanded="@(IsGroupActive("Logs") || IsActive("Setup", "Settings") || IsActive("Setup", "Profile")).ToString().ToLowerInvariant()">
                        <span>System</span><span class="chevron"></span>
                    </button>
                    <div id="systemMenu" class="collapse @(IsGroupActive("Logs") || IsActive("Setup", "Settings") || IsActive("Setup", "Profile") ? "show" : "")" data-bs-parent="#sidebarMenu">
                        <a class="sidebar-link @(IsActive("Logs", "ActivityLogs") ? "active" : "")" asp-controller="Logs" asp-action="ActivityLogs">Activity Logs</a>
                        <a class="sidebar-link @(IsActive("Setup", "Settings") ? "active" : "")" asp-controller="Setup" asp-action="Settings">Settings</a>
                        <a class="sidebar-link @(IsActive("Setup", "Profile") ? "active" : "")" asp-controller="Setup" asp-action="Profile">Profile</a>
                    </div>
                </div>
            </nav>
        </aside>

        <main class="app-main">
            <header class="top-navbar">
                <nav class="top-location" aria-label="Current location">
                    <span class="top-location-module">@module</span>
                    @if (!string.Equals(module, title, StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="top-location-separator" aria-hidden="true">/</span>
                        <span class="top-location-page">@title</span>
                    }
                </nav>
                <div class="top-user dropdown">
                    <button class="profile-toggle dropdown-toggle" type="button" id="profileMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="profile-avatar" aria-hidden="true">@UserInitials(username)</span>
                        <span class="profile-name">@username</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end profile-menu" aria-labelledby="profileMenuButton">
                        <form asp-controller="SignIn" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button class="dropdown-item profile-menu-item" type="submit">Logout</button>
                        </form>
                    </div>
                </div>
            </header>
            <div class="app-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
